{
	"manifest_version": 3,
	"name": "Functions",
	"description": "Annotate webpage elements with notes",
	"version": "1.0",
	"permissions": [
		"activeTab"
	],
	"action": {
		"default_popup": "index.html",
		"default_title": "Functions"
	},
	"content_scripts": [
		{
			"matches": [
				"<all_urls>"
			],
			"js": [
				"scripts/webpage.js"
			],
			"css": [
				"webpage.css"
			]
		}
	],
	"icons": {
		"16": "images/icon-16.png",
		"32": "images/icon-32.png",
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	}
}